# ── Server ──────────────────────────────────────────────
PORT=4000
# Comma-separated list of allowed frontend origins (your live Netlify URL)
ALLOWED_ORIGINS=https://asabites70.netlify.app,http://localhost:8888

# ── Admin auth ──────────────────────────────────────────
# JWT signing secret — replace with a long random string (e.g. run: openssl rand -hex 32)
JWT_SECRET=replace_this_with_a_long_random_string
# Admin login credentials — the seed script (npm run seed-admin) hashes ADMIN_PASSWORD into the database
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# ── Company info (used in emails / letters / WhatsApp messages) ──
COMPANY_NAME=ASA Foods
COMPANY_SIGNATORY=Mohammad Ashraf Khan
COMPANY_SIGNATORY_TITLE=Founder & CEO, ASA Group of Companies
COMPANY_ADDRESS=170 Tilak Nagar, Behind Girls Hostel, Kotri Chhawani, Kota - 324007, Rajasthan
COMPANY_PHONE=+91 78773 01391
COMPANY_ADMIN_EMAIL=asacloudkitchen50@gmail.com

# ── Email (choose ONE provider and fill in its section) ──
# Option A: Gmail SMTP with an App Password (Google Account > Security > App Passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_16_char_app_password

# ── WhatsApp — Meta WhatsApp Cloud API (free tier via developers.facebook.com) ──
# Create an app at developers.facebook.com > WhatsApp > API Setup to get these
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_or_temporary_access_token
WHATSAPP_API_VERSION=v20.0

# ── Settlement reminder schedule ──
# Cron expression for the Friday reminder (default: every Friday at 9:00 AM IST)
SETTLEMENT_CRON=0 9 * * 5
TIMEZONE=Asia/Kolkata
